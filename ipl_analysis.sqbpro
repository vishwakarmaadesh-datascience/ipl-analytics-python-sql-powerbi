<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="ipl_new.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3421"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="matches" custom_title="0" dock_id="5" table="4,7:mainmatches"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="matches" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="85"/><column index="2" value="62"/><column index="3" value="117"/><column index="4" value="300"/><column index="5" value="218"/><column index="6" value="218"/><column index="7" value="218"/><column index="8" value="83"/><column index="9" value="75"/><column index="10" value="93"/><column index="11" value="75"/><column index="12" value="93"/><column index="13" value="218"/><column index="14" value="78"/><column index="15" value="80"/><column index="16" value="98"/><column index="17" value="140"/><column index="18" value="140"/><column index="19" value="171"/><column index="20" value="171"/><column index="21" value="171"/><column index="22" value="171"/><column index="23" value="71"/><column index="24" value="300"/><column index="25" value="300"/><column index="26" value="74"/><column index="27" value="93"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">--1.Total IPL Matches
SELECT COUNT(*) AS total_matches
FROM ipl_matches_cleaned;
--2.Total Seasons
SELECT COUNT(DISTINCT season) AS total_seasons
FROM ipl_matches_cleaned;
--3.Total Teams
SELECT COUNT(DISTINCT winner) AS total_teams
FROM ipl_matches_cleaned;
--4.Matches Per Season
SELECT season,
       COUNT(*) AS matches
FROM ipl_matches_cleaned
GROUP BY season
ORDER BY season;
--5.Matches Played By Teams
SELECT team,COUNT(*) AS matches_played
FROM (
    SELECT team1 AS team FROM ipl_matches_cleaned
    UNION ALL
    SELECT team2 AS team FROM ipl_matches_cleaned
)
GROUP BY team
ORDER BY matches_played DESC;
--6.Most Successful Teams
SELECT winner,
       COUNT(*) AS wins
FROM ipl_matches_cleaned
GROUP BY winner
ORDER BY wins DESC;
--7.Win Percentage
WITH matches_played AS (
    SELECT team,
           COUNT(*) AS played
    FROM (
        SELECT team1 AS team
        FROM ipl_matches_cleaned
        UNION ALL
        SELECT team2 AS team
        FROM ipl_matches_cleaned
    )
    GROUP BY team
),
matches_won AS (
    SELECT winner AS team,
           COUNT(*) AS wins
    FROM ipl_matches_cleaned
    GROUP BY winner
)
SELECT p.team,
       p.played,
       w.wins,
       ROUND(
           (w.wins * 100.0 / p.played),
           2
       ) AS win_percentage

FROM matches_played p
JOIN matches_won w
ON p.team = w.team
ORDER BY win_percentage DESC;

--8.Teams Winning Most While Chasing
SELECT winner,
       COUNT(*) AS chase_wins
FROM ipl_matches_cleaned
WHERE win_by_wickets &gt; 0
GROUP BY winner
ORDER BY chase_wins DESC;

--9.Toss Winners
SELECT toss_winner,
       COUNT(*) AS tosses_won
FROM ipl_matches_cleaned
GROUP BY toss_winner
ORDER BY tosses_won DESC;
--10. Toss Winner Also Won Match
SELECT toss_winner,
       COUNT(*) AS toss_match_wins
FROM ipl_matches_cleaned
WHERE toss_winner = winner
GROUP BY toss_winner
ORDER BY toss_match_wins DESC;
--11.Toss Decision Frequency
SELECT toss_decision,
       COUNT(*) AS frequency
FROM ipl_matches_cleaned
GROUP BY toss_decision;
--12.Highest Scoring Venues
SELECT venue,
       AVG(team1_runs + team2_runs) AS avg_runs
FROM ipl_matches_cleaned
GROUP BY venue
ORDER BY avg_runs DESC;
--13.Lowest Scoring Venues
SELECT venue,
       AVG(team1_runs + team2_runs) AS avg_runs
FROM ipl_matches_cleaned
GROUP BY venue
ORDER BY avg_runs ASC;
--14.Biggest Wins By Runs
SELECT winner,
       MAX(win_by_runs) AS biggest_win
FROM ipl_matches_cleaned
GROUP BY winner
ORDER BY biggest_win DESC;
--15.Biggest Wins By Wickets
SELECT winner,
       MAX(win_by_wickets) AS biggest_chase
FROM ipl_matches_cleaned
GROUP BY winner
ORDER BY biggest_chase DESC;
--16.Close Matches
SELECT team1,
       team2,
       winner,
       win_by_runs
FROM ipl_matches_cleaned
WHERE win_by_runs &lt;= 5
AND win_by_runs &gt; 0;
--17.Most Player Of Match Awards
SELECT player_of_match,
       COUNT(*) AS awards
FROM ipl_matches_cleaned
GROUP BY player_of_match
ORDER BY awards DESC;
--18.Player Of Match By Season
SELECT season,
       player_of_match,
       COUNT(*) AS awards
FROM ipl_matches_cleaned
GROUP BY season, player_of_match
ORDER BY season, awards DESC;
--Columns
PRAGMA table_info(matches);
--ADDING A NEW COLUMN
ALTER TABLE matches
ADD COLUMN match_type TEXT;
--SET ALL MATCHES AS LEAGUE FIRST
UPDATE matches
SET match_type = 'League';
--MARK FINALS
UPDATE matches
SET match_type = 'Final'
WHERE date IN (

    SELECT MAX(date)
    FROM matches
    GROUP BY season

);
--19.MOST TROPHIES
SELECT winner,
       COUNT(*) AS trophies
FROM matches
WHERE match_type = 'Final'
GROUP BY winner
ORDER BY trophies DESC;

--Making Playoffs Columns
ALTER TABLE matches
ADD COLUMN playoff_stage TEXT;
UPDATE matches
SET playoff_stage = 'League';
--Marking finals
UPDATE matches
SET playoff_stage = 'Final'
WHERE rowid IN (

    SELECT rowid
    FROM (

        SELECT rowid,
               ROW_NUMBER() OVER(
                   PARTITION BY season
                   ORDER BY date DESC
               ) AS rn
        FROM matches

    )

    WHERE rn = 1

);

--Marking Qualifier 2
UPDATE matches
SET playoff_stage = 'Qualifier 2'
WHERE rowid IN (

    SELECT rowid
    FROM (

        SELECT rowid,
               ROW_NUMBER() OVER(
                   PARTITION BY season
                   ORDER BY date DESC
               ) AS rn
        FROM matches

    )

    WHERE rn = 2

);

--Marking Eliminator
UPDATE matches
SET playoff_stage = 'Eliminator'
WHERE rowid IN (

    SELECT rowid
    FROM (

        SELECT rowid,
               ROW_NUMBER() OVER(
                   PARTITION BY season
                   ORDER BY date DESC
               ) AS rn
        FROM matches

    )

    WHERE rn = 3

);

--Marking Qualifier1
UPDATE matches
SET playoff_stage = 'Qualifier 1'
WHERE rowid IN (

    SELECT rowid
    FROM (

        SELECT rowid,
               ROW_NUMBER() OVER(
                   PARTITION BY season
                   ORDER BY date DESC
               ) AS rn
        FROM matches

    )

    WHERE rn = 4

);

--20.Most Playoffs Apperances
SELECT team,
       COUNT(*) AS playoff_matches
FROM (

    SELECT team1 AS team
    FROM matches
    WHERE playoff_stage != 'League'

    UNION ALL

    SELECT team2 AS team
    FROM matches
    WHERE playoff_stage != 'League'

)

GROUP BY team
ORDER BY playoff_matches DESC;

--21.MOST PLAYOFF WINS
SELECT winner,
       COUNT(*) AS playoff_wins
FROM matches
WHERE playoff_stage != 'League'
GROUP BY winner
ORDER BY playoff_wins DESC;

--22.MOst final played
SELECT team,
       COUNT(*) AS finals_played
FROM (

    SELECT team1 AS team
    FROM matches
    WHERE playoff_stage = 'Final'

    UNION ALL

    SELECT team2 AS team
    FROM matches
    WHERE playoff_stage = 'Final'

)

GROUP BY team
ORDER BY finals_played DESC;

--23.Most final lost
SELECT loser,
       COUNT(*) AS finals_lost
FROM (

    SELECT team1 AS loser
    FROM matches
    WHERE playoff_stage = 'Final'
    AND winner = team2

    UNION ALL

    SELECT team2 AS loser
    FROM matches
    WHERE playoff_stage = 'Final'
    AND winner = team1

)

GROUP BY loser
ORDER BY finals_lost DESC;

--24.MOST PLAYER OF MATCH AWARDS IN PLAYOFFS
SELECT player_of_match,
       COUNT(*) AS playoff_awards
FROM matches
WHERE playoff_stage != 'League'
GROUP BY player_of_match
ORDER BY playoff_awards DESC;

--25.MOST PLAYER OF MATCH AWARDS IN FINALS
SELECT player_of_match,
       COUNT(*) AS final_awards
FROM matches
WHERE playoff_stage = 'Final'
GROUP BY player_of_match
ORDER BY final_awards DESC;

--26.MOST DOMINANT TEAM IN IPL HISTORY
WITH played AS (
    SELECT team,
           COUNT(*) AS matches_played
    FROM (
        SELECT team1 AS team
        FROM matches
        UNION ALL
        SELECT team2 AS team
        FROM matches
    )
    GROUP BY team
),
won AS (
    SELECT winner AS team,
           COUNT(*) AS wins
    FROM matches
    GROUP BY winner
)
SELECT p.team,
       p.matches_played,
       w.wins,
       ROUND(
           (w.wins * 100.0 / p.matches_played),
           2
       ) AS win_percentage

FROM played p
JOIN won w
ON p.team = w.team
WHERE p.matches_played &gt;= 50
ORDER BY win_percentage DESC;
 
--26.BEST CHASING TEAM
SELECT winner,
       COUNT(*) AS chase_wins
FROM matches
WHERE win_by_wickets &gt; 0
GROUP BY winner
ORDER BY chase_wins DESC;

--30.BEST DEFENDING TEAM
SELECT winner,
       COUNT(*) AS defend_wins
FROM matches
WHERE win_by_runs &gt; 0
GROUP BY winner
ORDER BY defend_wins DESC;

--31.BIGGEST IPL CHOKERS
SELECT loser,
       COUNT(*) AS defeats
FROM (
    SELECT team1 AS loser
    FROM matches
    WHERE winner = team2
    UNION ALL
    SELECT team2 AS loser
    FROM matches
    WHERE winner = team1

)
GROUP BY loser
ORDER BY defeats DESC;

--32.MOST SUCCESSFUL VENUES
SELECT venue,
       winner,
       COUNT(*) AS wins
FROM matches
GROUP BY venue, winner
ORDER BY wins DESC;

--33.TEAMS THAT BENEFIT MOST FROM TOSS
SELECT toss_winner,
       COUNT(*) AS toss_and_match_wins
FROM matches
WHERE toss_winner = winner
GROUP BY toss_winner
ORDER BY toss_and_match_wins DESC;

--34.MOST ONE-SIDED TEAM
SELECT winner,
       ROUND(
           AVG(win_by_runs),
           2
       ) AS avg_win_margin
FROM matches
WHERE win_by_runs &gt; 0
GROUP BY winner
ORDER BY avg_win_margin DESC;

--35.MOST SUCCESSFUL IPL SEASON
SELECT season,
       winner,
       COUNT(*) AS wins
FROM matches
GROUP BY season, winner
ORDER BY wins DESC;

--36.MOST ENTERTAINING SEASONS
SELECT season,
       ROUND(
           AVG(team1_runs + team2_runs),
           2
       ) AS avg_runs

FROM matches
GROUP BY season
ORDER BY avg_runs DESC;

--37.MOST CONSISTENT TEAM(Playoffs+Trophies)
WITH playoff_counts AS (
    SELECT team,
           COUNT(*) AS playoff_apps
    FROM (
        SELECT team1 AS team
        FROM matches
        WHERE playoff_stage != 'League'
        UNION ALL
        SELECT team2 AS team
        FROM matches
        WHERE playoff_stage != 'League'

    )
    GROUP BY team
),
trophy_counts AS (
    SELECT winner AS team,
           COUNT(*) AS trophies
    FROM matches
    WHERE playoff_stage = 'Final'
    GROUP BY winner
)
SELECT p.team,
       p.playoff_apps,
       t.trophies
FROM playoff_counts p
LEFT JOIN trophy_counts t
ON p.team = t.team
ORDER BY playoff_apps DESC, trophies DESC;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
